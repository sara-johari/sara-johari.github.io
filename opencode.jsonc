{
    "$schema": "https://opencode.ai/config.json",
    "model": "zai-coding-plan/glm-5.1",
    "small_model": "zai-coding-plan/glm-5-turbo", //configure a smaller model for faster response and less cost
    "autoupdate": true,
    "server": { //configure server settings for opencode serve and opencode web 
        "port": 4096,
        "hostname": "0.0.0.0",
        "mdns": true,
        "mdnsDomain": "sara-johari.github.io.local",
        "cors": ["http://localhost:3000"]
    },
    "tools": { //manage tools LLM can use
        "write": true,
        "bash": true
    }

    }
